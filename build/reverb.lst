  81:reverb.cpp    **** 
  82:reverb.cpp    ****     // Knob 2: Tone — one-pole lowpass on the wet signal
  83:reverb.cpp    ****     // We keep ReverbSc's internal LP wide open (fixed at 18kHz)
  84:reverb.cpp    ****     // and apply our own filter after the reverb for full control.
  85:reverb.cpp    ****     // The filter coefficient controls how much signal passes through:
  86:reverb.cpp    ****     //   coeff near 0.0 = very dark (heavily filtered)
  87:reverb.cpp    ****     //   coeff near 1.0 = bright (filter barely active)
  88:reverb.cpp    ****     // We map the knob through a power curve so the bright end is
  89:reverb.cpp    ****     // more gradual and the dark end is more dramatic.
  90:reverb.cpp    ****     // Full CCW = 0.02 (very dark), Full CW = 0.9999 (fully open/bright)
  91:reverb.cpp    ****     float knob2 = ReadKnobWithCV(ADC_10, CV_2);
