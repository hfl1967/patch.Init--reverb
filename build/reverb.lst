  16:reverb.cpp    **** // LED BEHAVIOR:
  17:reverb.cpp    **** //   - Front panel red LED lights when input signal exceeds kPeakThreshold
  18:reverb.cpp    **** //   - Stays on for kPeakHoldTicks callbacks then turns off
  19:reverb.cpp    **** //   - Tune kPeakThreshold: raise if always on, lower if never lights
  20:reverb.cpp    **** //
  21:reverb.cpp    **** // BLOCK SIZE:
