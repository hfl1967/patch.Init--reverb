  92:reverb.cpp    ****     // Invert: full CW = bright (low coeff = filter open)
  93:reverb.cpp    ****     //         full CCW = dark (high coeff = filter damps highs)
  94:reverb.cpp    ****     float toneCoeff = 0.9799f - powf(knob2, 2.0f) * 0.9599f;
  95:reverb.cpp    ****     // powf(x, 2.0) = squared curve — most of the knob sweep is open/bright,
