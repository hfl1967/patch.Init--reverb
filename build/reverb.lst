 148:reverb.cpp    ****         // Apply standalone one-pole lowpass to wet signal (tone knob)
 149:reverb.cpp    ****         // Formula: output = coeff * output_prev + (1 - coeff) * input
 150:reverb.cpp    ****         // Higher coeff = more of the previous output kept = darker/smoother
 151:reverb.cpp    ****         // This is a simple but effective and musical-sounding filter
 152:reverb.cpp    ****         toneFilterStateL = toneCoeff * toneFilterStateL + (1.f - toneCoeff) * sendL;
