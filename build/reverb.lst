  35:reverb.cpp    **** // --- Pre-delay circular buffer ---
  36:reverb.cpp    **** // 100ms at 48kHz = 4800 samples per channel
  37:reverb.cpp    **** static const int kPreDelayMaxSamples = 4800;
  38:reverb.cpp    **** float preDelayBufL[kPreDelayMaxSamples];
  39:reverb.cpp    **** float preDelayBufR[kPreDelayMaxSamples];
  40:reverb.cpp    **** int preDelayWrite = 0;
  41:reverb.cpp    **** 
  42:reverb.cpp    **** // --- Tone filter state ---
  43:reverb.cpp    **** // One-pole lowpass filter applied to the wet reverb signal.
  44:reverb.cpp    **** // This sits outside ReverbSc so we have full, predictable control.
  45:reverb.cpp    **** // Two state variables, one per channel, persist between callbacks.
  46:reverb.cpp    **** float toneFilterStateL = 0.0f;
  47:reverb.cpp    **** float toneFilterStateR = 0.0f;
  48:reverb.cpp    **** 
  49:reverb.cpp    **** // --- LED settings ---
  50:reverb.cpp    **** volatile float ledVoltage = 0.0f;
  51:reverb.cpp    **** 
  52:reverb.cpp    **** // --- Helpers ---
  53:reverb.cpp    **** float ReadKnob(int adcIndex)
  54:reverb.cpp    **** {
  55:reverb.cpp    ****     return fclamp(hw.GetAdcValue(adcIndex), 0.0f, 1.0f);
  56:reverb.cpp    **** }
  57:reverb.cpp    **** 
  58:reverb.cpp    **** float ReadCV(int cvIndex)
  59:reverb.cpp    **** {
  60:reverb.cpp    ****     return fclamp(hw.GetAdcValue(cvIndex), 0.0f, 1.0f);
  61:reverb.cpp    **** }
  62:reverb.cpp    **** 
  63:reverb.cpp    **** // Combines knob + CV. CV is centered so 0V = no offset.
  64:reverb.cpp    **** float ReadKnobWithCV(int knobAdc, int cvAdc)
  65:reverb.cpp    **** {
  66:reverb.cpp    ****     float knob = ReadKnob(knobAdc);
  67:reverb.cpp    ****     float cv = ReadCV(cvAdc) - 0.5f;
  68:reverb.cpp    ****     return fclamp(knob + cv, 0.0f, 1.0f);
  69:reverb.cpp    **** }
