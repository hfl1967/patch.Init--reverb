   1:reverb.cpp    **** // reverb.cpp
   2:reverb.cpp    **** // A simple stereo reverb for the Electrosmith patch.Init()
   3:reverb.cpp    **** // Uses the ReverbSc algorithm from DaisySP-LGPL.
   4:reverb.cpp    **** //
   5:reverb.cpp    **** // CONTROLS:
   6:reverb.cpp    **** //   Knob 1 + CV 1: Reverb time (power curve — long tails in upper range)
   7:reverb.cpp    **** //   Knob 2 + CV 2: Tone — standalone one-pole filter on wet signal
   8:reverb.cpp    **** //                  Full CCW = dark/muffled, Full CW = bright/open
   9:reverb.cpp    **** //   Knob 3 + CV 3: Wet/dry mix (full CCW = dry, full CW = wet)
  10:reverb.cpp    **** //   Knob 4 + CV 4: Pre-delay (0ms to 100ms)
  11:reverb.cpp    **** //
  12:reverb.cpp    **** // AUDIO BEHAVIOR:
  13:reverb.cpp    **** //   - If only the LEFT input is patched, right channel mirrors left (mono mode)
  14:reverb.cpp    **** //   - If both inputs are patched, runs in true stereo
